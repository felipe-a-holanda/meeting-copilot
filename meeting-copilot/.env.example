# Meeting Copilot — Environment Variables
# Copy this file to .env and fill in your values.

# ── Audio Pipeline ─────────────────────────────────────────────────────────────
# Whisper model size: tiny, base, small, medium, large-v2, large-v3, large-v3-turbo
WHISPER_MODEL=turbo

# Transcription language (ISO 639-1 code). Leave blank for auto-detect.
LANGUAGE=pt

# ── LLM — Local (Ollama) ───────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434

# Model for routine tasks (summaries, action items)
OLLAMA_MODEL=llama3.1:8b

# Heavier model for contradictions, reply suggestions (optional; falls back to OLLAMA_MODEL)
OLLAMA_HEAVY_MODEL=llama3.1:70b

# ── LLM — API Fallback (Anthropic Claude) ──────────────────────────────────────
# Set USE_API_FALLBACK=true to use Claude for heavy reasoning tasks
USE_API_FALLBACK=false
ANTHROPIC_API_KEY=

# ── Reasoning Trigger Thresholds ───────────────────────────────────────────────
# How many new segments before triggering a summary update
SUMMARY_EVERY_N_SEGMENTS=10

# How many new segments before scanning for action items
ACTION_SCAN_EVERY_N_SEGMENTS=5

# How often (seconds) to run contradiction detection
CONTRADICTION_CHECK_SECONDS=120

# ── WebSocket / Server ─────────────────────────────────────────────────────────
WS_HOST=0.0.0.0
WS_PORT=8000

# ── Storage ────────────────────────────────────────────────────────────────────
DB_PATH=meetings.db

